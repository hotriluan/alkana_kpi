# Marketing Dashboard - Git Ignore

# Database files (contain sensitive campaign data)
data/
*.db
*.db-shm
*.db-wal

# Environment variables (contain API keys)
.env
.env.local
.env.*.local

# Node modules
node_modules/
server/node_modules/
app/node_modules/

# Build outputs
app/dist/
server/dist/

# Generated local workflow artifacts
plans/
temp/
coverage/
coverage_output.txt
server/coverage_output.txt

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
